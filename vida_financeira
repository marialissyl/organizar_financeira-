<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Controle de Salário</title>

  <style>
    body {
      background: #5f067a;
      color: white;
      font-family: Arial;
      overflow: hidden;
      text-align: center;
    }

    input {
      padding: 5px;
      margin: 5px;
    }

    button {
      padding: 10px 20px;
      cursor: pointer;
    }

    .animacao {
      position: absolute;
      font-size: 30px;
      animation: subir linear forwards;
    }

    @keyframes subir {
      0% {
        transform: translateY(100vh);
        opacity: 1;
      }
      100% {
        transform: translateY(-10vh);
        opacity: 0;
      }
    }
  </style>
</head>

<body>

  <h1>Calcular dinheiro que sobrou</h1>

  <label>Salário:</label>
  <input type="number" id="salario">

  <br>

  <label>Compras:</label>
  <input type="number" id="compras">

  <br>

  <label>Despesa:</label>
  <input type="number" id="dispesa">

  <br><br>

  <button onclick="calcular()">Calcular</button>

  <h2 id="resultado"></h2>

<script>

function calcular() {

  let salario = Number(document.getElementById("salario").value);
  let compras = Number(document.getElementById("compras").value);
  let despesa = Number(document.getElementById("dispesa").value);

  let sobrou = salario - compras - despesa;

  document.getElementById("resultado").innerHTML =
    "Sobrou: Podemos mimar R$ " + sobrou;

  criarAnimacao();
}

// 🎈🐻 MUITA animação
function criarAnimacao() {

  for (let i = 0; i < 80; i++) {

    let el = document.createElement("div");
    el.classList.add("animacao");

    el.innerHTML = Math.random() > 0.5 ? "🎈" : "🐻";

    el.style.left = Math.random() * 100 + "vw";
    el.style.fontSize = (20 + Math.random() * 40) + "px";
    el.style.animationDuration = (2 + Math.random() * 3) + "s";

    document.body.appendChild(el);

    setTimeout(() => {
      el.remove();
    }, 5000);
  }
}

</script>

</body>
</html>
